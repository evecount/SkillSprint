
{
  "entities": {
    "Organization": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Organization",
      "type": "object",
      "description": "The multi-tenant root. Represents a discrete professional ecosystem or white-label client.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Learner": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Learner",
      "type": "object",
      "description": "A professional identity in the Registry. Can be an Apprentice (seeking) or Practitioner (mentoring).",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "organizationId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["learner", "teacher", "admin"] },
        "currentXp": { "type": "number" },
        "currentDailyStreak": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "organizationId", "email", "role"]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "description": "A 'Wisdom Portal' representing a high-stakes professional apprenticeship cycle.",
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "authorId": { "type": "string", "description": "UID of the Practitioner" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "isPublished": { "type": "boolean" }
      },
      "required": ["id", "organizationId", "authorId", "title"]
    },
    "AIConversation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AIConversation",
      "type": "object",
      "description": "A persistent digital asset capturing the professional intent and consultation history of a learner.",
      "properties": {
        "id": { "type": "string" },
        "learnerId": { "type": "string" },
        "organizationId": { "type": "string" },
        "topicSummary": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "learnerId", "organizationId", "startTime"]
    },
    "AIChatMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AIChatMessage",
      "type": "object",
      "description": "An individual interaction node within an AIConversation. Used for AI memory reconstruction.",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "sender": { "type": "string", "enum": ["learner", "ai"] },
        "messageText": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["conversationId", "sender", "messageText", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/organizations/{organizationId}",
        "definition": {
          "entityName": "Organization",
          "schema": { "$ref": "#/backend/entities/Organization" },
          "description": "Multi-tenant root."
        }
      },
      {
        "path": "/organizations/{organizationId}/learners/{learnerId}",
        "definition": {
          "entityName": "Learner",
          "schema": { "$ref": "#/backend/entities/Learner" },
          "description": "Professional profile and identity registry."
        }
      },
      {
        "path": "/organizations/{organizationId}/learners/{learnerId}/aiConversations/{conversationId}",
        "definition": {
          "entityName": "AIConversation",
          "schema": { "$ref": "#/backend/entities/AIConversation" },
          "description": "Digital assets representing the user's professional journey and AI-guided architecture."
        }
      },
      {
        "path": "/organizations/{organizationId}/learners/{learnerId}/aiConversations/{conversationId}/chatMessages/{messageId}",
        "definition": {
          "entityName": "AIChatMessage",
          "schema": { "$ref": "#/backend/entities/AIChatMessage" },
          "description": "Atomic units of conversation history used to provide Proctor with long-term memory."
        }
      }
    ]
  }
}
